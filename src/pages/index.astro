---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="page-container">

    <section class="hero">

      <!-- FOTO ARRIBA DERECHA -->
      <div class="profile-image">
        <img src="/FotoYo.jpeg" alt="Hernando Javier Garcia Mogollon" />
      </div>

      <!-- TEXTO PRINCIPAL -->
      <div class="hero-content">
        <h1>Nandoski666</h1>
        <h2>Hernando Javier Garcia Mogollon</h2>

        <p>
          Desarrollador enfocado en aplicaciones web,
          sistemas empresariales y proyectos tecnológicos modernos.
        </p>

        <p>
          Aquí comparto mis proyectos, aprendizajes y evolución como desarrollador.
        </p>
      </div>

    </section>

    <!-- SECCIÓN VIDEO -->
    <section class="video-section">
      <h3>🎥 Video Presentación</h3>

      <div class="video-container">
<iframe 
  width="100%" 
  height="400"
  src="https://www.youtube.com/embed/tNzKPYG7nXs"
  title="Video presentación"
  frameborder="0"
  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
  allowfullscreen>
</iframe>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
.page-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 3rem 1.5rem;
}

.hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 3rem;
  margin-bottom: 4rem;
}

.hero-content {
  flex: 1;
}

.hero h1 {
  font-size: 2.8rem;
  margin-bottom: 0.5rem;
}

.hero h2 {
  font-size: 1.3rem;
  font-weight: 400;
  color: #666;
  margin-bottom: 1.5rem;
}

.hero p {
  font-size: 1.05rem;
  line-height: 1.6;
  margin-bottom: 1rem;
  color: #444;
}

/* FOTO */
.profile-image {
  flex-shrink: 0;
}

.profile-image img {
  width: 180px;
  height: 180px;
  object-fit: cover;
  border-radius: 50%;
  border: 4px solid #eee;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

/* VIDEO */
.video-section {
  margin-top: 3rem;
}

.video-section h3 {
  margin-bottom: 1.5rem;
  font-size: 1.4rem;
}

.video-container {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  height: 0;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 15px 40px rgba(0,0,0,0.12);
}

.video-container iframe {
  position: absolute;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
}
</style>