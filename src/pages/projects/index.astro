---
/**
 * Ejercicios SQL
 * Route: /proyect
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'Ejercicios SQL — Nandoski666';
---

<BaseLayout>
  <main class="page-container">
    <header class="page-header">
      <h1>{pageTitle}</h1>
      <p class="page-intro">
        Aquí están las tres consultas solicitadas (Ejercicio 1, Ejercicio 2 y Ejercicio 3).
      </p>
    </header>

    <!-- Ejercicio 1 -->
    <section class="exercise">
      <h2>Ejercicio 1</h2>
      <p class="enunciado">Identificar los empleados que han tenido más de un registro en su historial de cargos (empleados con historial laboral múltiple).</p>
      <pre><code>
SELECT E.FIRST_NAME,
       H.EMPLOYEE_ID,
       COUNT(H.JOB_ID) AS job_count
FROM HR.JOB_HISTORY H
JOIN HR.EMPLOYEES E
     ON E.EMPLOYEE_ID = H.EMPLOYEE_ID
GROUP BY E.FIRST_NAME, H.EMPLOYEE_ID
HAVING COUNT(H.JOB_ID) > 1
ORDER BY job_count DESC;
      </code></pre>
    </section>

    <!-- Ejercicio 2 -->
    <section class="exercise">
      <h2>Ejercicio 2</h2>
      <p class="enunciado">
        Identifique todos los empleados que vivan o trabajen en Europa y que tengan un salario entre 4.000 y 6.000 dólares.
        Mostrar columnas: 1) Nombre y apellidos (una sola columna), 2) País al que pertenece, 3) Salario.
      </p>
      <pre><code>
SELECT
  E.FIRST_NAME || ' ' || E.LAST_NAME AS empleado,
  C.COUNTRY_NAME AS pais,
  E.SALARY AS salario
FROM HR.EMPLOYEES E
LEFT JOIN HR.DEPARTMENTS D
  ON E.DEPARTMENT_ID = D.DEPARTMENT_ID
LEFT JOIN HR.LOCATIONS L
  ON D.LOCATION_ID = L.LOCATION_ID
LEFT JOIN HR.COUNTRIES C
  ON L.COUNTRY_ID = C.COUNTRY_ID
LEFT JOIN HR.REGIONS R
  ON C.REGION_ID = R.REGION_ID
WHERE R.REGION_NAME = 'Europe'
  AND E.SALARY BETWEEN 4000 AND 6000
ORDER BY E.SALARY DESC;
      </code></pre>
    </section>

    <!-- Ejercicio 3 -->
    <section class="exercise">
      <h2>Ejercicio 3</h2>
      <p class="enunciado">
        Proyectar orden jerárquico de los cargos de los empleados: mostrar el nombre del empleado y su (sus) jefe(s) y extraer emails de ambos
        (mostrar las primeras 3 letras y rellenar con 6 asteriscos a la izquierda).
      </p>
      <pre><code>
SELECT 
    e.first_name || ' ' || e.last_name AS empleado,
    m.first_name || ' ' || m.last_name AS jefe,
    LPAD(SUBSTR(e.email,1,3), 9, '*') AS email_empleado,
    LPAD(SUBSTR(m.email,1,3), 9, '*') AS email_jefe
FROM HR.EMPLOYEES e
LEFT JOIN HR.EMPLOYEES m
    ON e.manager_id = m.employee_id
ORDER BY m.employee_id, e.employee_id;
      </code></pre>
    </section>

  </main>

  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.25rem;
    }

    .page-header h1 {
      margin-bottom: 0.5rem;
    }

    .page-intro {
      margin-bottom: 1.5rem;
      color: var(--color-muted, #666);
    }

    .exercise {
      margin: 2rem 0;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border, #e6e6e6);
    }

    .exercise h2 {
      margin-bottom: 0.25rem;
    }

    .enunciado {
      margin: 0.25rem 0 0.75rem;
      color: var(--color-muted, #555);
      font-style: italic;
    }

    pre {
      background: #0b0b0b;
      color: #e6e6e6;
      padding: 1rem;
      border-radius: 6px;
      overflow: auto;
    }

    code {
      font-family: monospace;
      font-size: 0.95rem;
      white-space: pre;
      display: block;
    }
  </style>
</BaseLayout>