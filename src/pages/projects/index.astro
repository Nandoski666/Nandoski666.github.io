---
/**
 * Portafolio de Desarrollo PL/SQL & SQL
 * Route: /projects
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'Portafolio de Desarrollo PL/SQL & SQL';
---

<BaseLayout>
  <main class="page-container">
    <header class="page-header">
      <h1>{pageTitle}</h1>
      <p class="page-intro">
        Consolidado técnico de ejercicios de bases de datos Oracle, cubriendo desde fundamentos hasta objetos programables complejos.
      </p>
    </header>

    <h3 class="phase-title">Fase 1: Fundamentos y Consultas de Estructura</h3>

    <section class="exercise">
      <h2>1. Mi Primer Script PL/SQL: Saludo al Entorno</h2>
      <p class="enunciado">Primer bloque anónimo en Oracle para validar la conexión y salida de consola con DBMS_OUTPUT.</p>
      <pre><code>
BEGIN
  DBMS_OUTPUT.PUT_LINE('Hola Mundo PL/SQL');
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>2. Análisis de Rotación: Empleados con Múltiples Roles</h2>
      <p class="enunciado">Consulta SQL avanzada para identificar talentos que han ocupado más de un cargo histórico en la empresa.</p>
      <pre><code>
SELECT employee_id, COUNT(*) AS total_roles
FROM job_history
GROUP BY employee_id
HAVING COUNT(*) > 1;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>3. Lógica Base: Declaración y Control de Variables</h2>
      <p class="enunciado">Uso de la sección DECLARE para gestionar tipos de datos escalares y su impresión dinámica.</p>
      <pre><code>
DECLARE
  v_test VARCHAR2(20) := 'Nando Dev';
BEGIN
  DBMS_OUTPUT.PUT_LINE('Valor: ' || v_test);
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>4. Geolocalización Salarial: Filtro de Nómina Europea</h2>
      <p class="enunciado">Consulta relacional multitabla (JOINs) para filtrar empleados por región geográfica y rango de ingresos.</p>
      <pre><code>
SELECT e.first_name, e.salary, r.region_name
FROM employees e
JOIN departments d ON e.department_id = d.department_id
JOIN locations l ON d.location_id = l.location_id
JOIN countries c ON l.country_id = c.country_id
JOIN regions r ON c.region_id = r.region_id
WHERE r.region_name = 'Europe' AND e.salary BETWEEN 5000 AND 10000;
      </code></pre>
    </section>

    <h3 class="phase-title">Fase 2: Manejo de Datos y Atributos</h3>

    <section class="exercise">
      <h2>5. Extracción Directa: Consulta Dinámica de Perfiles</h2>
      <p class="enunciado">Implementación de SELECT INTO para recuperar e inyectar datos de la tabla empleados en variables locales.</p>
      <pre><code>
DECLARE
  v_fname employees.first_name%TYPE;
  v_lname employees.last_name%TYPE;
BEGIN
  SELECT first_name, last_name INTO v_fname, v_lname 
  FROM employees WHERE employee_id = 100;
  DBMS_OUTPUT.PUT_LINE(v_fname || ' ' || v_lname);
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>6. Estructura Organizacional y Seguridad de Datos</h2>
      <p class="enunciado">Generación de reporte jerárquico con enmascaramiento selectivo de correos electrónicos corporativos.</p>
      <pre><code>
SELECT LPAD(' ', 2*(LEVEL-1)) || first_name AS empleado,
       RPAD(SUBSTR(email, 1, 2), LENGTH(email), '*') AS email_hidden
FROM employees
START WITH manager_id IS NULL
CONNECT BY PRIOR employee_id = manager_id;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>7. Automatización de Tipado: Vinculación vía %TYPE</h2>
      <p class="enunciado">Uso de anclaje de tipos para garantizar que las variables mantengan consistencia con las columnas de la tabla HR.</p>
      <pre><code>
DECLARE
  v_sal employees.salary%TYPE;
BEGIN
  SELECT salary INTO v_sal FROM employees WHERE employee_id = 120;
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>8. Gestión de Respaldos: Clonación de Estructuras (CTAS)</h2>
      <p class="enunciado">Creación rápida de tablas físicas basadas en consultas filtradas para asegurar la disponibilidad de información.</p>
      <pre><code>
CREATE TABLE emp_backup AS 
SELECT * FROM employees WHERE department_id = 80;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>9. Mapeo de Entidades: Captura de Filas con %ROWTYPE</h2>
      <p class="enunciado">Optimización de memoria al cargar un registro completo de la tabla en una sola variable de estructura múltiple.</p>
      <pre><code>
DECLARE
  v_emp_rec employees%ROWTYPE;
BEGIN
  SELECT * INTO v_emp_rec FROM employees WHERE employee_id = 105;
  DBMS_OUTPUT.PUT_LINE(v_emp_rec.email);
END;
      </code></pre>
    </section>

    <h3 class="phase-title">Fase 3: Lógica Algorítmica y Control</h3>

    <section class="exercise">
      <h2>10. Modelado Relacional: Desarrollo de Sistema Bibliotecario</h2>
      <p class="enunciado">Diseño y creación de tablas desde cero para la gestión de activos editoriales.</p>
      <pre><code>
CREATE TABLE libros (
    isbn VARCHAR2(20) PRIMARY KEY,
    titulo VARCHAR2(100),
    autor VARCHAR2(50),
    precio NUMBER(8,2)
);
      </code></pre>
    </section>

    <section class="exercise">
      <h2>11. Auditoría de Esquemas: Mapeo del Propietario NESPINOSAE</h2>
      <p class="enunciado">Consulta de metadatos del diccionario de datos de Oracle para listar objetos pertenecientes a un usuario específico.</p>
      <pre><code>
SELECT table_name FROM all_tables WHERE owner = 'NESPINOSAE';
      </code></pre>
    </section>

    <section class="exercise">
      <h2>12. Validación de Cómputo: Algoritmo de Días Primos (IF)</h2>
      <p class="enunciado">Uso de estructuras condicionales anidadas para determinar propiedades matemáticas del calendario.</p>
      <pre><code>
DECLARE
  v_dia NUMBER := TO_NUMBER(TO_CHAR(SYSDATE, 'DD'));
  v_primo BOOLEAN := TRUE;
BEGIN
  IF v_dia &lt; 2 THEN v_primo := FALSE;
  ELSE
    FOR i IN 2..TRUNC(v_dia/2) LOOP
      IF MOD(v_dia, i) = 0 THEN v_primo := FALSE; EXIT; END IF;
    END LOOP;
  END IF;
  IF v_primo THEN DBMS_OUTPUT.PUT_LINE(v_dia || ' es primo');
  ELSE DBMS_OUTPUT.PUT_LINE(v_dia || ' no es primo'); END IF;
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>13. Salto de Control: Flujo Lógico con Etiquetas GOTO</h2>
      <p class="enunciado">Demostración técnica de redireccionamiento de flujo mediante etiquetas identificadoras en PL/SQL.</p>
      <pre><code>
DECLARE
  v_dia NUMBER := TO_NUMBER(TO_CHAR(SYSDATE, 'DD'));
BEGIN
  IF v_dia &lt; 2 THEN GOTO no_primo; END IF;
  &lt;&lt;es_primo&gt;&gt; DBMS_OUTPUT.PUT_LINE(v_dia || ' es primo'); RETURN;
  &lt;&lt;no_primo&gt;&gt; DBMS_OUTPUT.PUT_LINE(v_dia || ' no es primo');
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>14. Secuencias Infinitas: Generador Fibonacci con LOOP</h2>
      <p class="enunciado">Algoritmo iterativo para proyectar la sucesión de Fibonacci hasta un límite determinado.</p>
      <pre><code>
DECLARE
  a NUMBER := 0; b NUMBER := 1; t NUMBER;
BEGIN
  LOOP
    EXIT WHEN a &gt; 1000;
    DBMS_OUTPUT.PUT_LINE(a);
    t := a + b; a := b; b := t;
  END LOOP;
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>15. Optimización Euclidiana: Cálculo de MCM vía WHILE</h2>
      <p class="enunciado">Implementación del algoritmo de Euclides para el cálculo del Mínimo Común Múltiplo.</p>
      <pre><code>
DECLARE
  v_num1 NUMBER := 12; v_num2 NUMBER := 18;
  v_a NUMBER := v_num1; v_b NUMBER := v_num2;
BEGIN
  WHILE v_b != 0 LOOP
    v_a := MOD(v_a, v_b);
    SELECT v_a, v_b INTO v_b, v_a FROM dual;
  END LOOP;
  DBMS_OUTPUT.PUT_LINE('MCM: ' || (v_num1 * v_num2) / v_a);
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>16. Búsqueda Determinada: Proyección de Raíz Entera (FOR)</h2>
      <p class="enunciado">Evaluación sistémica para encontrar si un número X posee raíz cuadrada exacta en el conjunto de enteros.</p>
      <pre><code>
DECLARE
  v_x NUMBER := 25;
BEGIN
  FOR i IN 1..v_x LOOP
    IF i * i = v_x THEN
      DBMS_OUTPUT.PUT_LINE('Raíz entera: ' || i);
      EXIT;
    END IF;
  END LOOP;
END;
      </code></pre>
    </section>

    <h3 class="phase-title">Fase 4: Objetos Programables</h3>

    <section class="exercise">
      <h2>17. Lógica Reutilizable: Procedimientos de Gestión Salarial</h2>
      <p class="enunciado">Desarrollo de objetos persistentes para la actualización masiva y segura de datos sensibles.</p>
      <pre><code>
CREATE OR REPLACE PROCEDURE upd_salary(p_id IN NUMBER, p_percent IN NUMBER) IS
BEGIN
  UPDATE employees SET salary = salary * (1 + p_percent/100) WHERE employee_id = p_id;
  COMMIT;
END;
      </code></pre>
    </section>

    <section class="exercise">
      <h2>18. Procesamiento de Conjuntos: Cursores Parametrizados</h2>
      <p class="enunciado">Iteración profesional sobre juegos de datos mediante cursores explícitos con paso de parámetros.</p>
      <pre><code>
DECLARE
  CURSOR c_dept(p_id NUMBER) IS SELECT first_name FROM employees WHERE department_id = p_id;
BEGIN
  FOR r_emp IN c_dept(50) LOOP
    DBMS_OUTPUT.PUT_LINE('Nombre: ' || r_emp.first_name);
  END LOOP;
END;
      </code></pre>
    </section>

  </main>

  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.25rem;
    }

    .page-header h1 {
      margin-bottom: 0.5rem;
    }

    .page-intro {
      margin-bottom: 1.5rem;
      color: var(--color-muted, #666);
    }
    
    .phase-title {
      margin-top: 4rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 3px solid #3b82f6; /* Azul vibrante */
      color: #3b82f6;
      font-size: 1.75rem;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .exercise {
      margin: 2.5rem 0;
      padding-bottom: 1rem;
    }

    .exercise h2 {
      margin-bottom: 0.1rem;
      font-size: 1.4rem;
      color: var(--color-primary, #fff);
    }

    .enunciado {
      margin: 0.25rem 0 0.75rem;
      color: var(--color-muted, #999);
      font-style: italic;
      line-height: 1.5;
    }

    pre {
      background: #0b1117;
      color: #e6edf3;
      padding: 1.25rem;
      border-radius: 8px;
      overflow: auto;
      border: 1px solid #30363d;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    code {
      font-family: 'Fira Code', 'Cascadia Code', monospace;
      font-size: 0.9rem;
      line-height: 1.6;
      white-space: pre;
      display: block;
    }
  </style>
</BaseLayout>